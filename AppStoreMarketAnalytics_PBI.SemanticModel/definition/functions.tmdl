function PoP_Perc =
		( _measure : expr ) =>
		VAR _StartDate = MIN('dim_calendar'[Date])
		VAR _EndDate   = MAX('dim_calendar'[Date])
		VAR _PeriodLen = DATEDIFF(_StartDate, _EndDate, DAY) + 1
		VAR _PrevStart = _StartDate - _PeriodLen
		VAR _PrevEnd   = _StartDate - 1
		VAR _CurrVal =
		    CALCULATE(
		        _measure,
		        FILTER(ALL('dim_calendar'),
		            'dim_calendar'[Date] >= _StartDate &&
		            'dim_calendar'[Date] <= _EndDate
		        )
		    )
		VAR _PrevVal =
		    CALCULATE(
		        _measure,
		        FILTER(ALL('dim_calendar'),
		            'dim_calendar'[Date] >= _PrevStart &&
		            'dim_calendar'[Date] <= _PrevEnd
		        )
		    )
		RETURN DIVIDE(_CurrVal - _PrevVal, _PrevVal, BLANK())
	lineageTag: 491f0b23-f1a0-4991-976b-e976d0c1cff3

function PoP_Icon =
		( _measure : expr ) =>
		VAR _StartDate = MIN('dim_calendar'[Date])
