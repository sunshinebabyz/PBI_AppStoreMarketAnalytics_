		RETURN IF(ISBLANK(d), "–", IF(d >= 0, Up, Down) & " " & FORMAT(ABS(d), "0.0%"))
	lineageTag: 40c499c9-eee2-41e3-b95d-ddc1d62b834d

function Delta_Color =
		( _value : expr ) =>
		VAR IsText    = NOT ISNONTEXT(_value)
		VAR HasUp     = IsText && CONTAINSSTRING(_value, "▲")
		VAR HasDown   = IsText && CONTAINSSTRING(_value, "▼")
		VAR Cleaned1  = IF(IsText, SUBSTITUTE(SUBSTITUTE(_value, "▲", ""), "▼", ""), _value)
		VAR Cleaned2  = IF(IsText, SUBSTITUTE(Cleaned1, "%", ""), Cleaned1)
		VAR NumRaw    = IF(ISBLANK(_value), BLANK(), IF(IsText, DIVIDE(VALUE(Cleaned2), 100), _value))
		VAR NumSigned = IF(IsText && (HasUp || HasDown), IF(HasDown, -ABS(NumRaw), ABS(NumRaw)), NumRaw)
		RETURN
		    SWITCH(
		        TRUE(),
		        ISBLANK(NumSigned), "#B0B0B0",
		        NumSigned > 0,      "#54DFBF",
		        NumSigned < 0,      "#EB704A",
		                            "#5A5A5A"
		    )
	lineageTag: fb80de48-ec2c-477b-81a1-3809285d4369

function Delta_Color_Inverse =
		( _value : expr ) =>
		VAR IsText    = NOT ISNONTEXT(_value)
		VAR HasUp     = IsText && CONTAINSSTRING(_value, "▲")
		VAR HasDown   = IsText && CONTAINSSTRING(_value, "▼")
		VAR Cleaned1  = IF(IsText, SUBSTITUTE(SUBSTITUTE(_value, "▲", ""), "▼", ""), _value)
		VAR Cleaned2  = IF(IsText, SUBSTITUTE(Cleaned1, "%", ""), Cleaned1)
		VAR NumRaw    = IF(ISBLANK(_value), BLANK(), IF(IsText, DIVIDE(VALUE(Cleaned2), 100), _value))
		VAR NumSigned = IF(IsText && (HasUp || HasDown), IF(HasDown, -ABS(NumRaw), ABS(NumRaw)), NumRaw)
		RETURN
		    SWITCH(
		        TRUE(),
		        ISBLANK(NumSigned), "#B0B0B0",
		        NumSigned > 0,      "#EB704A",
		        NumSigned < 0,      "#54DFBF",
		                            "#5A5A5A"
		    )
	lineageTag: 3b92b7d9-f5bb-4af6-ab79-5f08aa7efcc2

function MoM_MTD_Perc =
		( _measure : expr ) =>
		VAR CM_MTD = CALCULATE( _measure, DATESMTD( dim_calendar[Date] ) )
		VAR PM_MTD = CALCULATE( _measure, DATEADD( DATESMTD( dim_calendar[Date] ), -1, MONTH ) )
		RETURN DIVIDE( CM_MTD - PM_MTD, PM_MTD, BLANK() )
	lineageTag: 65af12b0-85e8-4c0b-8fd7-c86f1f96ad73

